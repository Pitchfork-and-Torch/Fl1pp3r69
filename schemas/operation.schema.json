{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flipper69.local/schemas/operation.schema.json",
  "title": "Flipper69 Operation",
  "description": "Field operation record (v3 VEIL LEDGER). v2 documents without schemaVersion remain readable.",
  "type": "object",
  "required": ["opId", "opType", "phase", "openedAt", "device"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 2,
      "maximum": 3,
      "description": "3 = VEIL LEDGER; omit or 2 = legacy v2"
    },
    "opId": {
      "type": "string",
      "pattern": "^op-[0-9]{8}-[a-z0-9-]+$"
    },
    "codename": { "type": "string" },
    "workspace": { "type": "string" },
    "opType": {
      "type": "string",
      "enum": ["proximity", "survey", "replay", "inject", "unified"]
    },
    "pathnum": { "type": "integer", "minimum": 1, "maximum": 5 },
    "pathLabel": {
      "type": "string",
      "enum": ["imps", "ds", "slow", "fast", "emerg"]
    },
    "phase": {
      "type": "string",
      "enum": ["intake", "op_prep", "probe", "capture", "verify", "exfil", "close"]
    },
    "session": {
      "type": "integer",
      "minimum": 1,
      "description": "Multi-day session counter"
    },
    "templateId": {
      "type": ["string", "null"],
      "description": "Optional template id used at INTAKE"
    },
    "openedAt": {
      "type": "string",
      "format": "date-time"
    },
    "closedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "device": {
      "type": "object",
      "required": ["firmware"],
      "properties": {
        "firmware": { "type": "string", "const": "flipper69" },
        "version": { "type": "string" },
        "codename": { "type": "string" },
        "serial": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "notes": { "type": "string" },
        "authorized": { "type": "boolean", "default": false }
      }
    },
    "captureCount": { "type": "integer", "minimum": 0 },
    "manifestHash": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "releaseCodename": { "type": "string" },
    "permissions": {
      "type": "object",
      "properties": {
        "opsec": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "txEnabled": { "type": "boolean" },
        "replayConfirmed": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
